{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.local/regulatory-guideline-archive/derived/core.schema.json",
  "title": "Derived Contract Core Definitions",
  "definitions": {
    "derivedModelVersion": {
      "const": "0.1.0"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "nullableId": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "nullableString": {
      "type": ["string", "null"]
    },
    "idArray": {
      "type": "array",
      "items": { "$ref": "#/definitions/id" },
      "uniqueItems": true
    },
    "nonEmptyIdArray": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/id" },
      "uniqueItems": true
    },
    "date": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "dateTime": {
      "type": "string",
      "minLength": 1
    },
    "regulatorProfile": {
      "type": "string",
      "enum": ["core", "ich"]
    },
    "aggregateReviewStatus": {
      "type": "string",
      "enum": ["unreviewed", "needs_review", "reviewed", "rejected"]
    },
    "reviewPolicy": {
      "type": "string",
      "enum": ["include_needs_review", "reviewed_only"]
    },
    "reviewOutcome": {
      "type": "string",
      "enum": ["passed", "needs_review", "rejected"]
    },
    "reviewerType": {
      "type": "string",
      "enum": ["validator", "model", "human", "legacy_repository_review"]
    },
    "riskLevel": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "requiredReviewTier": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "riskFactor": {
      "type": "string",
      "enum": [
        "draft_final_withdrawn_status_uncertainty",
        "unclear_publication_or_effective_date",
        "unclear_replacement_or_supplementation_scope",
        "addendum_or_partial_amendment_structure",
        "integrated_versus_consolidated_structure",
        "complex_layout_tables_notes_ocr_or_cross_references",
        "likely_impact_on_current_effective_records"
      ]
    },
    "derivationBasis": {
      "type": "string",
      "enum": [
        "direct_source",
        "consolidated_source",
        "amendment_synthesis",
        "supplementary_source",
        "reviewed_cross_document_synthesis"
      ]
    },
    "amendmentRelationType": {
      "type": "string",
      "enum": [
        "clarifies",
        "supplements",
        "modifies",
        "narrows",
        "broadens",
        "replaces",
        "supersedes",
        "conflicts_with"
      ]
    },
    "documentEditionRole": {
      "description": "The logical role this edition plays in its guidance family, per Module 3.6.",
      "type": "string",
      "enum": [
        "draft",
        "final",
        "revised_final",
        "addendum",
        "qa",
        "annex",
        "supplement",
        "withdrawal_notice",
        "replacement_notice",
        "integrated_package",
        "textually_consolidated_edition"
      ]
    },
    "documentStatus": {
      "description": "The edition's own publication lifecycle state (draft/in force/withdrawn/superseded), an input to effective-state determination. It is not itself a claim that this edition is the currently effective content for any jurisdiction or as_of_date; that is computed by EffectiveRecord and EffectiveStateSnapshot from document_status, publication/effective dates, and lifecycle relationships.",
      "type": "string",
      "enum": [
        "draft",
        "in_force",
        "withdrawn",
        "superseded"
      ]
    },
    "sourceRole": {
      "description": "The role a given source Document plays for a DocumentEdition. EditionSource is a one-or-many link from an edition to its source Document(s) (Module 3.6); primary identifies the edition's principal source Document, and supplementary identifies an additional source Document jointly backing the same edition (for example a textually consolidated edition assembled from more than one source PDF). Exactly one EditionSource per edition should be primary.",
      "type": "string",
      "enum": [
        "primary",
        "supplementary"
      ]
    },
    "jurisdiction": {
      "type": "string",
      "minLength": 1
    },
    "documentLevelSourceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["document_id"],
      "properties": {
        "document_id": { "$ref": "#/definitions/id" }
      }
    },
    "sourceUnitLevelSourceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["document_id", "section_id", "source_unit_id"],
      "properties": {
        "document_id": { "$ref": "#/definitions/id" },
        "section_id": { "$ref": "#/definitions/id" },
        "source_unit_id": { "$ref": "#/definitions/id" }
      }
    },
    "representationLimitation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["limitation_text", "affected_cross_reference_ids", "affected_record_ids"],
      "properties": {
        "limitation_text": { "$ref": "#/definitions/nonEmptyString" },
        "affected_cross_reference_ids": { "$ref": "#/definitions/idArray" },
        "affected_record_ids": { "$ref": "#/definitions/idArray" }
      },
      "anyOf": [
        {
          "properties": {
            "affected_cross_reference_ids": { "$ref": "#/definitions/nonEmptyIdArray" }
          }
        },
        {
          "properties": {
            "affected_record_ids": { "$ref": "#/definitions/nonEmptyIdArray" }
          }
        }
      ]
    },
    "recordHistory": {
      "type": "object",
      "additionalProperties": false,
      "required": ["predecessor_record_ids"],
      "properties": {
        "predecessor_record_ids": { "$ref": "#/definitions/idArray" }
      }
    },
    "artifactEnvelope": {
      "type": "object",
      "required": ["derived_model_version", "artifact_type", "regulator_profile", "records"],
      "properties": {
        "derived_model_version": { "$ref": "#/definitions/derivedModelVersion" },
        "artifact_type": { "$ref": "#/definitions/nonEmptyString" },
        "regulator_profile": { "$ref": "#/definitions/regulatorProfile" },
        "records": {
          "type": "array",
          "minItems": 1
        }
      }
    }
  }
}
