{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.local/regulatory-guideline-archive/derived/artifacts/effective_record.schema.json",
  "title": "EffectiveRecord Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "derived_model_version",
    "artifact_type",
    "regulator_profile",
    "records"
  ],
  "properties": {
    "derived_model_version": {
      "$ref": "https://example.local/regulatory-guideline-archive/derived/core.schema.json#/definitions/derivedModelVersion"
    },
    "artifact_type": {
      "const": "EffectiveRecord"
    },
    "regulator_profile": {
      "$ref": "https://example.local/regulatory-guideline-archive/derived/core.schema.json#/definitions/regulatorProfile"
    },
    "records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/effectiveRecord"
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "regulator_profile": {
            "const": "core"
          }
        },
        "required": [
          "regulator_profile"
        ]
      },
      "then": {
        "properties": {
          "records": {
            "items": {
              "properties": {
                "profile_details": {
                  "type": "null"
                }
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "regulator_profile": {
            "const": "ich"
          }
        },
        "required": [
          "regulator_profile"
        ]
      },
      "then": {
        "properties": {
          "records": {
            "items": {
              "allOf": [
                {
                  "if": {
                    "properties": {
                      "derivation_basis": {
                        "enum": [
                          "amendment_synthesis",
                          "supplementary_source"
                        ]
                      }
                    },
                    "required": [
                      "derivation_basis"
                    ]
                  },
                  "then": {
                    "properties": {
                      "profile_details": {
                        "$ref": "https://example.local/regulatory-guideline-archive/derived/profiles/ich.schema.json#/definitions/effectiveRecordProfileDetails"
                      }
                    }
                  },
                  "else": {
                    "properties": {
                      "profile_details": {
                        "type": "null"
                      }
                    }
                  }
                }
              ]
            }
          }
        }
      }
    }
  ],
  "definitions": {
    "effectiveRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "effective_record_id",
        "guidance_family_id",
        "document_edition_id",
        "jurisdiction",
        "as_of_date",
        "effective_status",
        "derivation_basis",
        "amendment_mapping_ids",
        "contributing_record_ids",
        "source_references",
        "effective_text_en",
        "normalized_ko",
        "synthesis_rationale",
        "representation_limitations",
        "review_status",
        "profile_details"
      ],
      "properties": {
        "effective_record_id": {
          "$ref": "https://example.local/regulatory-guideline-archive/derived/core.schema.json#/definitions/id"
        },
        "guidance_family_id": {
          "$ref": "https://example.local/regulatory-guideline-archive/derived/core.schema.json#/definitions/id"
        },
        "document_edition_id": {
          "$ref": "https://example.local/regulatory-guideline-archive/derived/core.schema.json#/definitions/id"
        },
        "jurisdiction": {
          "$ref": "https://example.local/regulatory-guideline-archive/derived/core.schema.json#/definitions/jurisdiction"
        },
        "as_of_date": {
          "$ref": "https://example.local/regulatory-guideline-archive/derived/core.schema.json#/definitions/date"
        },
        "effective_status": {
          "$ref": "https://example.local/regulatory-guideline-archive/derived/core.schema.json#/definitions/nonEmptyString"
        },
        "derivation_basis": {
          "$ref": "https://example.local/regulatory-guideline-archive/derived/core.schema.json#/definitions/derivationBasis"
        },
        "amendment_mapping_ids": {
          "$ref": "https://example.local/regulatory-guideline-archive/derived/core.schema.json#/definitions/idArray"
        },
        "contributing_record_ids": {
          "$ref": "https://example.local/regulatory-guideline-archive/derived/core.schema.json#/definitions/nonEmptyIdArray"
        },
        "source_references": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "https://example.local/regulatory-guideline-archive/derived/core.schema.json#/definitions/sourceUnitLevelSourceRef"
          }
        },
        "effective_text_en": {
          "$ref": "https://example.local/regulatory-guideline-archive/derived/core.schema.json#/definitions/nonEmptyString"
        },
        "normalized_ko": {
          "$ref": "https://example.local/regulatory-guideline-archive/derived/core.schema.json#/definitions/nullableString"
        },
        "synthesis_rationale": {
          "$ref": "https://example.local/regulatory-guideline-archive/derived/core.schema.json#/definitions/nonEmptyString"
        },
        "representation_limitations": {
          "type": "array",
          "items": {
            "$ref": "https://example.local/regulatory-guideline-archive/derived/core.schema.json#/definitions/representationLimitation"
          }
        },
        "review_status": {
          "$ref": "https://example.local/regulatory-guideline-archive/derived/core.schema.json#/definitions/aggregateReviewStatus"
        },
        "profile_details": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "https://example.local/regulatory-guideline-archive/derived/profiles/ich.schema.json#/definitions/effectiveRecordProfileDetails"
            }
          ]
        },
        "history": {
          "$ref": "https://example.local/regulatory-guideline-archive/derived/core.schema.json#/definitions/recordHistory"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "derivation_basis": {
                "const": "amendment_synthesis"
              }
            },
            "required": [
              "derivation_basis"
            ]
          },
          "then": {
            "properties": {
              "amendment_mapping_ids": {
                "$ref": "https://example.local/regulatory-guideline-archive/derived/core.schema.json#/definitions/nonEmptyIdArray"
              }
            }
          }
        }
      ]
    }
  }
}
