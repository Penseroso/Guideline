{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.local/regulatory-guideline-archive/derived/artifacts/risk_assessment.schema.json",
  "title": "RiskAssessment Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": ["derived_model_version", "artifact_type", "regulator_profile", "records"],
  "properties": {
    "derived_model_version": { "$ref": "https://example.local/regulatory-guideline-archive/derived/core.schema.json#/definitions/derivedModelVersion" },
    "artifact_type": { "const": "RiskAssessment" },
    "regulator_profile": { "$ref": "https://example.local/regulatory-guideline-archive/derived/core.schema.json#/definitions/regulatorProfile" },
    "technical_migration": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "https://example.local/regulatory-guideline-archive/derived/core.schema.json#/definitions/technicalMigration" }
      ]
    },
    "records": { "type": "array", "minItems": 1, "items": { "$ref": "#/definitions/riskAssessment" } }
  },
  "definitions": {
    "riskAssessment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["risk_assessment_id", "target_type", "target_id", "risk_level", "risk_factors", "rationale", "assessor_attestation_id", "assessed_at", "required_review_tier", "supersedes_risk_assessment_id", "override_reason", "override_attestation_id", "profile_details"],
      "properties": {
        "risk_assessment_id": { "$ref": "https://example.local/regulatory-guideline-archive/derived/core.schema.json#/definitions/id" },
        "target_type": { "$ref": "https://example.local/regulatory-guideline-archive/derived/core.schema.json#/definitions/nonEmptyString" },
        "target_id": { "$ref": "https://example.local/regulatory-guideline-archive/derived/core.schema.json#/definitions/id" },
        "risk_level": { "$ref": "https://example.local/regulatory-guideline-archive/derived/core.schema.json#/definitions/riskLevel" },
        "risk_factors": { "type": "array", "minItems": 1, "items": { "$ref": "https://example.local/regulatory-guideline-archive/derived/core.schema.json#/definitions/riskFactor" }, "uniqueItems": true },
        "rationale": { "$ref": "https://example.local/regulatory-guideline-archive/derived/core.schema.json#/definitions/nonEmptyString" },
        "assessor_attestation_id": { "$ref": "https://example.local/regulatory-guideline-archive/derived/core.schema.json#/definitions/nullableId" },
        "assessed_at": { "$ref": "https://example.local/regulatory-guideline-archive/derived/core.schema.json#/definitions/dateTime" },
        "required_review_tier": { "$ref": "https://example.local/regulatory-guideline-archive/derived/core.schema.json#/definitions/requiredReviewTier" },
        "supersedes_risk_assessment_id": { "$ref": "https://example.local/regulatory-guideline-archive/derived/core.schema.json#/definitions/nullableId" },
        "override_reason": { "$ref": "https://example.local/regulatory-guideline-archive/derived/core.schema.json#/definitions/nullableString" },
        "override_attestation_id": { "$ref": "https://example.local/regulatory-guideline-archive/derived/core.schema.json#/definitions/nullableId" },
        "profile_details": { "type": "null" },
        "history": { "$ref": "https://example.local/regulatory-guideline-archive/derived/core.schema.json#/definitions/recordHistory" }
      }
    }
  }
}
