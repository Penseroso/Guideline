{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.local/regulatory-guideline-archive/derived/artifacts/amendment_mapping.schema.json",
  "title": "AmendmentMapping Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": ["derived_model_version", "artifact_type", "regulator_profile", "records"],
  "properties": {
    "derived_model_version": { "$ref": "https://example.local/regulatory-guideline-archive/derived/core.schema.json#/definitions/derivedModelVersion" },
    "artifact_type": { "const": "AmendmentMapping" },
    "regulator_profile": { "$ref": "https://example.local/regulatory-guideline-archive/derived/core.schema.json#/definitions/regulatorProfile" },
    "technical_migration": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "https://example.local/regulatory-guideline-archive/derived/core.schema.json#/definitions/technicalMigration" }
      ]
    },
    "records": { "type": "array", "minItems": 1, "items": { "$ref": "#/definitions/amendmentMapping" } }
  },
  "definitions": {
    "amendmentMapping": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mapping_id", "guidance_family_id", "source_document_edition_id", "amending_document_edition_id", "source_record_ids", "amending_record_ids", "relation_type", "original_relationship_wording", "source_references", "review_status", "profile_details"],
      "properties": {
        "mapping_id": { "$ref": "https://example.local/regulatory-guideline-archive/derived/core.schema.json#/definitions/id" },
        "guidance_family_id": { "$ref": "https://example.local/regulatory-guideline-archive/derived/core.schema.json#/definitions/id" },
        "source_document_edition_id": { "$ref": "https://example.local/regulatory-guideline-archive/derived/core.schema.json#/definitions/id" },
        "amending_document_edition_id": { "$ref": "https://example.local/regulatory-guideline-archive/derived/core.schema.json#/definitions/id" },
        "source_record_ids": { "$ref": "https://example.local/regulatory-guideline-archive/derived/core.schema.json#/definitions/idArray" },
        "amending_record_ids": { "$ref": "https://example.local/regulatory-guideline-archive/derived/core.schema.json#/definitions/idArray" },
        "relation_type": { "$ref": "https://example.local/regulatory-guideline-archive/derived/core.schema.json#/definitions/amendmentRelationType" },
        "original_relationship_wording": { "$ref": "https://example.local/regulatory-guideline-archive/derived/core.schema.json#/definitions/nonEmptyString" },
        "source_references": { "type": "array", "minItems": 1, "items": { "$ref": "https://example.local/regulatory-guideline-archive/derived/core.schema.json#/definitions/sourceDocumentRef" } },
        "review_status": { "$ref": "https://example.local/regulatory-guideline-archive/derived/core.schema.json#/definitions/aggregateReviewStatus" },
        "profile_details": { "type": "null" },
        "history": { "$ref": "https://example.local/regulatory-guideline-archive/derived/core.schema.json#/definitions/recordHistory" }
      }
    }
  }
}
