{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.local/regulatory-guideline-archive/derived/artifacts/effective_state_snapshot.schema.json",
  "title": "EffectiveStateSnapshot Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "derived_model_version",
    "artifact_type",
    "regulator_profile",
    "records"
  ],
  "properties": {
    "derived_model_version": {
      "$ref": "https://example.local/regulatory-guideline-archive/derived/core.schema.json#/definitions/derivedModelVersion"
    },
    "artifact_type": {
      "const": "EffectiveStateSnapshot"
    },
    "regulator_profile": {
      "$ref": "https://example.local/regulatory-guideline-archive/derived/core.schema.json#/definitions/regulatorProfile"
    },
    "records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/effectiveStateSnapshot"
      }
    }
  },
  "definitions": {
    "effectiveStateSnapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "snapshot_id",
        "guidance_family_id",
        "jurisdiction",
        "as_of_date",
        "review_policy",
        "source_corpus_identity",
        "calculation_policy_version",
        "effective_record_ids",
        "calculated_at",
        "review_status",
        "profile_details"
      ],
      "properties": {
        "snapshot_id": {
          "$ref": "https://example.local/regulatory-guideline-archive/derived/core.schema.json#/definitions/id"
        },
        "guidance_family_id": {
          "$ref": "https://example.local/regulatory-guideline-archive/derived/core.schema.json#/definitions/id"
        },
        "jurisdiction": {
          "$ref": "https://example.local/regulatory-guideline-archive/derived/core.schema.json#/definitions/jurisdiction"
        },
        "as_of_date": {
          "$ref": "https://example.local/regulatory-guideline-archive/derived/core.schema.json#/definitions/date"
        },
        "review_policy": {
          "$ref": "https://example.local/regulatory-guideline-archive/derived/core.schema.json#/definitions/reviewPolicy"
        },
        "source_corpus_identity": {
          "$ref": "https://example.local/regulatory-guideline-archive/derived/core.schema.json#/definitions/nonEmptyString"
        },
        "calculation_policy_version": {
          "$ref": "https://example.local/regulatory-guideline-archive/derived/core.schema.json#/definitions/nonEmptyString"
        },
        "effective_record_ids": {
          "$ref": "https://example.local/regulatory-guideline-archive/derived/core.schema.json#/definitions/idArray"
        },
        "calculated_at": {
          "$ref": "https://example.local/regulatory-guideline-archive/derived/core.schema.json#/definitions/dateTime"
        },
        "review_status": {
          "$ref": "https://example.local/regulatory-guideline-archive/derived/core.schema.json#/definitions/aggregateReviewStatus"
        },
        "profile_details": {
          "type": "null"
        },
        "history": {
          "$ref": "https://example.local/regulatory-guideline-archive/derived/core.schema.json#/definitions/recordHistory"
        }
      }
    }
  }
}
