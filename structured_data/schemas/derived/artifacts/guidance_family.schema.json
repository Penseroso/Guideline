{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.local/regulatory-guideline-archive/derived/artifacts/guidance_family.schema.json",
  "title": "GuidanceFamily Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": ["derived_model_version", "artifact_type", "regulator_profile", "records"],
  "properties": {
    "derived_model_version": { "$ref": "https://example.local/regulatory-guideline-archive/derived/core.schema.json#/definitions/derivedModelVersion" },
    "artifact_type": { "const": "GuidanceFamily" },
    "regulator_profile": { "$ref": "https://example.local/regulatory-guideline-archive/derived/core.schema.json#/definitions/regulatorProfile" },
    "records": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/guidanceFamily" }
    }
  },
  "definitions": {
    "guidanceFamily": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "guidance_family_id",
        "family_title",
        "regulator_profile",
        "jurisdictions",
        "current_risk_assessment_id",
        "review_status",
        "profile_details"
      ],
      "properties": {
        "guidance_family_id": { "$ref": "https://example.local/regulatory-guideline-archive/derived/core.schema.json#/definitions/id" },
        "family_title": { "$ref": "https://example.local/regulatory-guideline-archive/derived/core.schema.json#/definitions/nonEmptyString" },
        "regulator_profile": { "$ref": "https://example.local/regulatory-guideline-archive/derived/core.schema.json#/definitions/regulatorProfile" },
        "jurisdictions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "https://example.local/regulatory-guideline-archive/derived/core.schema.json#/definitions/jurisdiction" },
          "uniqueItems": true
        },
        "current_risk_assessment_id": { "$ref": "https://example.local/regulatory-guideline-archive/derived/core.schema.json#/definitions/nullableId" },
        "review_status": { "$ref": "https://example.local/regulatory-guideline-archive/derived/core.schema.json#/definitions/aggregateReviewStatus" },
        "profile_details": { "$ref": "https://example.local/regulatory-guideline-archive/derived/core.schema.json#/definitions/profileDetails" }
      },
      "allOf": [
        {
          "if": { "properties": { "regulator_profile": { "const": "core" } }, "required": ["regulator_profile"] },
          "then": { "properties": { "profile_details": { "type": "null" } } }
        },
        {
          "if": { "properties": { "regulator_profile": { "const": "ich" } }, "required": ["regulator_profile"] },
          "then": { "properties": { "profile_details": { "$ref": "https://example.local/regulatory-guideline-archive/derived/profiles/ich.schema.json#/definitions/profileDetails" } } }
        }
      ]
    }
  }
}
